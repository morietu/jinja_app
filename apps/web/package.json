{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=dot",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:openapi": "pnpm -w lint:openapi",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:contract": "vitest run --reporter=dot --pool=threads",
    "guard:no-backend-direct": "rg -n \"(BACKEND_URL|https?://127\\\\.0\\\\.0\\\\.1:8000|https?://localhost:8000|https?://[^\\s'\\\"]+:8000)\" src --glob \"!src/app/api/**\" --glob \"!src/app/**/route.ts\" --glob \"!src/lib/server/**\" --glob \"!src/lib/bff/**\" --glob \"!src/**/*.test.*\" --glob \"!src/**/__tests__/**\" && (echo \"❌ Direct backend access found\" && exit 1) || exit 0",
    "guard:no-next-public-in-server": "rg -n \"NEXT_PUBLIC_\" src/lib/server src/app/api && (echo \"❌ NEXT_PUBLIC_* used in server code\" && exit 1) || exit 0"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/nextjs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "baseline-browser-mapping": "^2.10.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "serialize-javascript": "^7.0.5",
    "storybook": "10.3.5",
    "tailwindcss": "^4.2.2",
    "ts-prune": "^0.10.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
