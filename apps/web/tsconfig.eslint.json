{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "vitest.setup.ts",
    "lib/**/*",
    "packages/**/*",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mts",
    "src/**/*.cts",
    "src/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/app/**/tests/**/*"
  ],
  "exclude": ["node_modules", ".next", "dist", "coverage"]
}
