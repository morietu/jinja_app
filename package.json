{
  "name": "jinja_app",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "backend"
  ],
  "scripts": {
    "lint:openapi:ci": "npx spectral lint docs/openapi.yaml",
    "test:contract": "pnpm --filter ./apps/web test:contract",
    "lint:openapi": "npx -y @stoplight/spectral-cli lint docs/openapi.yaml",
    "prepare": "husky",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "lint:web": "pnpm -C apps/web run lint",
    "e2e:web": "pnpm -C apps/web run test:e2e",
    "guard:readme-fences": "bash -lc 'set -o pipefail; if rg -n \"^```\" README.md | rg -v \":\\\\s*```$\" | rg -v \":\\\\s*```(bash|javascript|typescript)$\"; then echo \"❌ invalid fence language found\"; exit 1; else echo \"✅ only allowed fence languages used\"; fi'"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.0.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.17.23",
      "js-yaml": "4.1.1",
      "glob": "11.1.0",
      "qs": "6.14.1"
    }
  }
}
